{
  "manifest_version": 3,
  "name": "ZenFB PoC",
  "version": "1.0",
  "description": "Proof of Concept for ZenFB Group Auto-Poster",
  "permissions": [
    "cookies",
    "storage",
    "tabs",
    "scripting",
    "webNavigation"
  ],
  "host_permissions": [
    "*://*.facebook.com/*",
    "https://ohhcpeverlfihwfghdpz.supabase.co/*"
  ],
"content_security_policy": {
  "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://ohhcpeverlfihwfghdpz.supabase.co"
},
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "assets/icon.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.facebook.com/*"],
      "js": ["content.js"]
    }
  ]
}
